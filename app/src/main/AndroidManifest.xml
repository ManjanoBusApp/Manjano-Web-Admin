<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:name=".ManjanoApp"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:supportsRtl="true"
        android:theme="@style/Theme.Manjano.NoActionBar"
        tools:ignore="GoogleAppIndexingWarning">

        <!-- Google Maps API Key — ONLY ONE TIME -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyAw9C7fTPJHwzl-KWiLPwaNjq0iYdXd7wo" />

        <!-- Main Launcher Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="unspecified">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Existing: Deep link for manjanoapp:// scheme -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="manjanoapp"
                    android:host="verify" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="manjanoapp" android:host="verification-success" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="manjanoapp" android:host="verification-failed" />
            </intent-filter>

            <!-- 🔥 NEW: Deep link for signin (existing active accounts) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="manjanoapp" android:host="signin" />
            </intent-filter>

            <!-- 🔥 NEW: Deep link for https:// web links (opens app directly) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="manjano-app.web.app"
                    android:pathPrefix="/verify" />
            </intent-filter>
        </activity>

        <activity
            android:name=".compose.ProfileSetupActivity"
            android:exported="false"
            android:screenOrientation="unspecified"
            android:theme="@style/Theme.Manjano.NoActionBar" />

        <activity
            android:name=".legacy.ProfileSetupActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

    </application>

</manifest>